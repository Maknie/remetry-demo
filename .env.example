# Copy to .env to point the demo at your own Remetry deployment.
# Defaults (used when unset) target a local stack with the seeded demo project.
# The GitHub Pages build (.github/workflows/deploy.yml) targets the live cloud
# instead: https://ingest.remetry.dev/ingest/events + dashboard app.remetry.dev.

VITE_REMETRY_DSN=demo-public-dsn
VITE_REMETRY_ENDPOINT=http://localhost:8080/ingest/events
VITE_REMETRY_RELEASE=demo@1.0.0
VITE_REMETRY_REPLAY_MODE=onError
VITE_DASHBOARD_URL=http://localhost:5173
VITE_MOCK_API_BASE=http://localhost:5174/__mock
VITE_BAD_RELEASE=false
